    "version": "1.0.0",
    "category": "Game Servers",
    "instanceType": "custom-command",
    "startupType": "native",
    "defaultRam": "1G",
    "defaultPorts": [
      7777
    ],
    "tags": [
      "terraria",
      "tshock",
      "game-server"
    ],
    "downloadSource": {
      "type": "url",
      "resolver": "github-release",
      "repo": "Pryaxis/TShock",
      "assetPattern": "linux.*x64.*\\.zip$",
      "fileName": "tshock.zip",
      "required": true
    },
    "downloads": [
      {
        "type": "url",
        "resolver": "github-release",
        "repo": "Pryaxis/TShock",
        "assetPattern": "linux.*x64.*\\.zip$",
        "destination": "data/tshock.zip",
        "fileName": "tshock.zip",
        "required": true,
        "overwrite": true
      }
    ],
    "installer": {
      "type": "archive",
      "archive": "tshock.zip",
      "extractDir": "server",
      "verifyFiles": [
        "server/TShock.Server"
      ],
      "timeoutMs": 300000
    },
    "startup": {
      "executable": "bash",
      "args": [
        "-lc",
        "chmod +x ./TShock.Server 2>/dev/null || true; exec ./TShock.Server -port {port} -world ./Worlds/world.wld -autocreate 2"
      ],
      "workingDirectory": "data/server",
      "restartPolicy": "on-failure"
    },
    "installMetadata": {
      "method": "github-release",
      "source": "Pryaxis/TShock latest Linux x64 release archive",
      "notes": "Requires unzip on the host. TShock may ask for an initial setup token in the console on first start."
    },
    "configNotes": "The first TShock start prints a setup code in the console. Use it to claim server admin in-game.",
    "installScript": [
      "create-instance",
      "verify-instance",
      "create-folders",
      "download",
      "install-archive",
      "write-config",
      "verify",
      "start"
    ],
    "configurationSchema": [
      "name",
      "storageLocation",
      "port",
      "memory"
    ],
    "installerType": "archive-download"
  },
