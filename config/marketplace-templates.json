      "notes": "Requires tar with xz support. A Cfx.re license key must be added to server.cfg before start."
    },
    "configNotes": "Edit server.cfg and replace CHANGE_ME_FIVEM_LICENSE_KEY with a valid Cfx.re license key before starting.",
    "installScript": [
      "create-instance",
      "verify-instance",
