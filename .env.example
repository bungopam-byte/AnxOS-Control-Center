# Sensitive AMP credentials stay in this file. Do not save AMP_PASSWORD in localStorage.
AMP_URL=http://192.168.1.134:8080
AMP_USERNAME=your_amp_username
AMP_PASSWORD=your_amp_password

# The Debian agent must be started with this same token.
AGENT_TOKEN=replace_with_shared_agent_token

# Discord bot secrets. Keep real values in .env only.
DISCORD_TOKEN=replace_with_discord_bot_token
CLIENT_ID=replace_with_discord_application_client_id
GUILD_ID=replace_with_development_guild_id_if_needed

# Required only for installing CurseForge Marketplace packs.
# CF_API_KEY matches common Auto-CurseForge tooling; CURSEFORGE_API_KEY is also supported.
# Wrap keys containing $ in single quotes when using .env.
CF_API_KEY='replace_with_curseforge_api_key'
# CF_API_KEY_FILE=/run/secrets/cf_api_key

# Optional online AnxOS account system.
# Desktop app points at the deployed Supabase Edge Function. This is not required for Single-Device Mode.
ANXOS_WEBSITE_BASE_URL=https://anxos-control-center.pages.dev
ANXOS_ACCOUNT_API_URL=https://your-project-ref.functions.supabase.co/anxos-account
ANXOS_SUPABASE_URL=https://your-project-ref.supabase.co
ANXOS_SUPABASE_ANON_KEY=replace_with_public_supabase_anon_key

# Optional desktop owner allowlist. Prefer scripts/bootstrap-owner-account.js for local setup.
# Comma-separated. These values are not secrets, but they should identify only trusted owner accounts.
ANXOS_OWNER_ACCOUNT_IDS=
ANXOS_OWNER_EMAILS=

# Server-only values for Supabase Edge Functions. Never expose these in website/account-config.js.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
ANXOS_DESKTOP_TOKEN_SECRET=replace_with_at_least_32_random_bytes
ANXOS_DEVICE_CODE_SECRET=replace_with_separate_32_random_bytes
ANXOS_ALLOWED_ORIGINS=https://anxos-control-center.pages.dev,http://localhost:4173
