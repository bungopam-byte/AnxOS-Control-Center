      ],
      "timeoutMs": 300000
    },
    "startup": {
      "executable": "bash",
      "args": [
        "-lc",
        "chmod +x ./run.sh 2>/dev/null || true; exec ./run.sh +exec server.cfg"
      ],
      "workingDirectory": "data/server",
