{
  "name": "anxos-control-center",
  "productName": "AnxOS Control Center",
  "version": "1.0.52",
  "description": "Private local desktop control center for a Debian server.",
  "homepage": "https://anxoscontrolcenter.org",
  "author": "Anx",
  "license": "UNLICENSED",
  "desktopName": "anxos-control-center.desktop",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "node scripts/run-electron-builder.js",
    "dist:win": "node scripts/run-electron-builder.js --win --x64",
    "dist:win:installer": "node scripts/run-electron-builder.js --win nsis --x64",
    "dist:win:portable": "node scripts/run-electron-builder.js --win portable --x64",
    "dist:linux": "node scripts/run-electron-builder.js --linux deb AppImage --x64",
    "build:increment": "node scripts/release-config.js build:increment",
    "version:set": "node scripts/release-config.js version:set",
    "channel:set": "node scripts/release-config.js channel:set",
    "updates:manifest": "node scripts/write-update-manifest.js && node scripts/sync-website-release.js",
    "website:sync": "node scripts/sync-website-release.js",
    "release:update": "node scripts/release-update.js",
    "agent:skills:check": ".agent/scripts/validate-skills",
    "agent:validate": ".agent/scripts/validate-project",
    "agent:release-check": ".agent/scripts/release-check",
    "amp:debug": "node scripts/amp-debug.js",
    "docker:smoke": "node scripts/docker-smoke.js",
    "account:smoke": "node scripts/account-system-smoke.js",
    "device-activation:smoke": "node scripts/device-activation-smoke.js",
    "owner-account:smoke": "node scripts/owner-account-smoke.js",
    "owner-bootstrap:smoke": "node scripts/bootstrap-owner-account-smoke.js",
    "account:diagnostics": "node scripts/account-diagnostics.js",
    "agent:token:status": "node scripts/agent-token-status.js",
    "agent:token:rotate": "node scripts/rotate-agent-token.js",
    "agent:pair": "node scripts/agent-pair-export.js",
    "agent:token:smoke": "node scripts/agent-token-smoke.js",
    "agent:instances:smoke": "node scripts/agent-instance-record-smoke.js",
    "instances:runtime:smoke": "node scripts/instance-runtime-smoke.js",
    "node:switch:smoke": "node scripts/node-switch-smoke.js",
    "node-health:smoke": "node scripts/node-health-smoke.js",
    "security:page:smoke": "node scripts/security-page-smoke.js",
    "owner:smoke": "node scripts/owner-workspace-smoke.js",
    "icons:linux": "node scripts/generate-linux-icons.js",
    "marketplace:smoke": "node scripts/marketplace-smoke.js",
    "curseforge:regression": "node scripts/curseforge-packaged-regression.js",
    "dependencies:smoke": "node scripts/dependency-smoke.js",
    "files:smoke": "node scripts/files-pipeline-smoke.js",
    "agent:files-root:smoke": "node scripts/agent-files-root-smoke.js",
    "instances:deletion:smoke": "node scripts/instance-deletion-smoke.js",
    "device-architecture:smoke": "node scripts/device-architecture-smoke.js",
    "local-owner-auth:smoke": "node scripts/local-owner-auth-smoke.js",
    "settings:preferences:smoke": "node scripts/settings-preferences-smoke.js",
    "settings:permissions:smoke": "node scripts/settings-permissions-smoke.js",
    "settings:permissions:runtime": "node scripts/settings-permissions-runtime-smoke.js",
    "onboarding:smoke": "node scripts/onboarding-smoke.js",
    "maintenance:smoke": "node scripts/maintenance-smoke.js",
    "global-search:smoke": "node scripts/global-search-smoke.js",
    "command-palette:smoke": "node scripts/command-palette-smoke.js",
    "renderer-safety:smoke": "node scripts/renderer-safety-smoke.js",
    "ui:polish:smoke": "node scripts/ui-polish-smoke.js",
    "public-access:smoke": "node scripts/public-access-smoke.js",
    "packaging:smoke": "node scripts/packaging-artifact-smoke.js",
    "release:artifacts:smoke": "node scripts/validate-release-artifacts.js --fixture",
    "website:smoke": "node scripts/website-production-smoke.js && node scripts/website-download-smoke.js && node scripts/website-accessibility-smoke.js",
    "website:a11y:smoke": "node scripts/website-accessibility-smoke.js",
    "website:download:smoke": "node scripts/website-download-smoke.js",
    "diagnostics:smoke": "node scripts/diagnostics-smoke.js",
    "versioning:smoke": "node scripts/versioning-smoke.js",
    "notifications:smoke": "node scripts/notification-center-smoke.js",
    "agent-control:smoke": "node scripts/agent-control-smoke.js",
    "windows-runtime:smoke": "node scripts/windows-runtime-smoke.js",
    "security:reset-password": "node scripts/reset-local-password.js",
    "icons:branding": "node scripts/generate-linux-icons.js"
  },
  "build": {
    "appId": "com.anxos.controlcenter",
    "productName": "AnxOS Control Center",
    "copyright": "Copyright © 2026 Anx",
    "afterPack": "scripts/normalize-package-permissions.js",
    "asarUnpack": [
      "src/shared/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "app.js",
      "index.html",
      "release.json",
      "release-build.json",
      "styles.css",
      "windows/**/*",
      "assets/**/*",
      "config/agent.example.json",
      "config/marketplace-templates.json",
      "config/ssh-profiles.json",
      "website/anxos-design-system.css",
      "website/account-config.js",
      "src/**/*",
      "src/shared/**/*",
      "agent/package.json",
      "agent/src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "agent",
        "to": "local-agent-runtime/agent",
        "filter": [
          "package.json",
          "src/**/*",
          "!agent.log",
          "!config/**/*",
          "!**/*.map",
          "!**/.env",
          "!**/.env.*",
          "!package-lock.json",
          "!node_modules/**/*"
        ]
      },
      {
        "from": "src/shared",
        "to": "local-agent-runtime/src/shared",
        "filter": [
          "**/*.js",
          "!**/*.map"
        ]
      },
      {
        "from": "config/agent.example.json",
        "to": "local-agent-runtime/config/agent.example.json"
      },
      {
        "from": "config/marketplace-templates.json",
        "to": "local-agent-runtime/config/marketplace-templates.json"
      },
      {
        "from": "config/local-agent-runtime.json",
        "to": "local-agent-runtime/local-agent-runtime.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "verifyUpdateCodeSignature": true,
      "signtoolOptions": {
        "publisherName": "Anx"
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icons/png",
      "executableName": "anxos-control-center",
      "syncDesktopName": true,
      "maintainer": "AnxOS <noreply@anxos.local>",
      "vendor": "AnxOS",
      "synopsis": "Private local desktop control center for a Debian server.",
      "description": "AnxOS Control Center is a private local desktop dashboard for homelab server monitoring and management.",
      "desktop": {
        "entry": {
          "Name": "AnxOS Control Center",
          "Comment": "Private local desktop control center for a Debian server",
          "StartupWMClass": "anxos-control-center"
        }
      }
    },
    "appImage": {
      "artifactName": "AnxOS-Control-Center-${env.ANXOS_RELEASE_ARTIFACT_VERSION}.${ext}"
    },
    "deb": {
      "artifactName": "AnxOS-Control-Center-${env.ANXOS_RELEASE_ARTIFACT_VERSION}.${ext}",
      "packageCategory": "utils"
    },
    "portable": {
      "artifactName": "AnxOS-Control-Center-${env.ANXOS_RELEASE_ARTIFACT_VERSION}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "AnxOS-Control-Center-Setup-${env.ANXOS_RELEASE_ARTIFACT_VERSION}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AnxOS Control Center",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@cubecoders/ampapi": "^1.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "monaco-editor": "^0.55.1",
    "ssh2": "^1.17.0",
    "unzipper": "^0.12.5"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "ssh2@1.17.0": true
  }
}
