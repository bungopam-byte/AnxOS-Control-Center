      "appId": 896660,
      "login": "anonymous",
      "required": true
    },
    "installer": {
      "type": "steamcmd",
      "appId": 896660,
      "installDir": "server",
      "login": "anonymous",
      "validate": true,
      "verifyFiles": [
        "server/valheim_server.x86_64"
      ],
      "timeoutMs": 600000
    },
    "startup": {
      "executable": "bash",
      "args": [
        "-lc",
        "chmod +x ./valheim_server.x86_64 2>/dev/null || true; export SteamAppId=892970; exec ./valheim_server.x86_64 -nographics -batchmode -name \"{name}\" -port {port} -world Dedicated -password changeme123 -public 1 -savedir saves"
      ],
      "workingDirectory": "data/server",
      "restartPolicy": "on-failure"
    },
    "installMetadata": {
      "method": "steamcmd",
      "appId": 896660,
      "login": "anonymous",
      "notes": "Requires steamcmd and compatible Linux dedicated-server dependencies on the host."
