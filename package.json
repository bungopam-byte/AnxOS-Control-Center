{
  "name": "anxos-control-center",
  "productName": "AnxOS Control Center",
  "version": "1.0.48",
  "description": "Private local desktop control center for a Debian server.",
  "author": "Anx",
  "license": "UNLICENSED",
  "desktopName": "anxos-control-center.desktop",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:win:installer": "electron-builder --win nsis --x64",
    "dist:win:portable": "electron-builder --win portable --x64",
    "dist:linux": "electron-builder --linux deb AppImage --x64",
    "updates:manifest": "node scripts/write-update-manifest.js && node scripts/sync-website-release.js",
    "website:sync": "node scripts/sync-website-release.js",
    "release:update": "node scripts/release-update.js",
    "agent:skills:check": ".agent/scripts/validate-skills",
    "agent:validate": ".agent/scripts/validate-project",
    "agent:release-check": ".agent/scripts/release-check",
    "amp:debug": "node scripts/amp-debug.js",
    "docker:smoke": "node scripts/docker-smoke.js",
    "account:smoke": "node scripts/account-system-smoke.js",
    "owner-account:smoke": "node scripts/owner-account-smoke.js",
    "owner-bootstrap:smoke": "node scripts/bootstrap-owner-account-smoke.js",
    "agent:token:status": "node scripts/agent-token-status.js",
    "agent:token:rotate": "node scripts/rotate-agent-token.js",
    "agent:pair": "node scripts/agent-pair-export.js",
    "agent:token:smoke": "node scripts/agent-token-smoke.js",
    "node:switch:smoke": "node scripts/node-switch-smoke.js",
    "security:page:smoke": "node scripts/security-page-smoke.js",
    "owner:smoke": "node scripts/owner-workspace-smoke.js",
    "icons:linux": "node scripts/generate-linux-icons.js",
    "marketplace:smoke": "node scripts/marketplace-smoke.js",
    "files:smoke": "node scripts/files-pipeline-smoke.js",
    "device-architecture:smoke": "node scripts/device-architecture-smoke.js",
    "local-owner-auth:smoke": "node scripts/local-owner-auth-smoke.js",
    "ui:polish:smoke": "node scripts/ui-polish-smoke.js",
    "diagnostics:smoke": "node scripts/diagnostics-smoke.js",
    "agent-control:smoke": "node scripts/agent-control-smoke.js",
    "windows-runtime:smoke": "node scripts/windows-runtime-smoke.js",
    "security:reset-password": "node scripts/reset-local-password.js"
  },
  "build": {
    "appId": "com.anxos.controlcenter",
    "productName": "AnxOS Control Center",
    "copyright": "Copyright © 2026 Anx",
    "files": [
      "main.js",
      "preload.js",
      "app.js",
      "index.html",
      "styles.css",
      "windows/**/*",
      "assets/**/*",
      "config/**/*",
      "website/account-config.js",
      "src/**/*",
      "agent/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "verifyUpdateCodeSignature": true,
      "signtoolOptions": {
        "publisherName": "Anx"
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icons/png",
      "executableName": "anxos-control-center",
      "syncDesktopName": true,
      "maintainer": "AnxOS <noreply@anxos.local>",
      "vendor": "AnxOS",
      "synopsis": "Private local desktop control center for a Debian server.",
      "description": "AnxOS Control Center is a private local desktop dashboard for homelab server monitoring and management.",
      "desktop": {
        "entry": {
          "Name": "AnxOS Control Center",
          "Comment": "Private local desktop control center for a Debian server",
          "StartupWMClass": "anxos-control-center"
        }
      }
    },
    "appImage": {
      "artifactName": "AnxOS-Control-Center-${version}.${ext}"
    },
    "deb": {
      "artifactName": "AnxOS-Control-Center-${version}.${ext}",
      "packageCategory": "utils"
    },
    "portable": {
      "artifactName": "AnxOS-Control-Center-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "AnxOS-Control-Center-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AnxOS Control Center",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@cubecoders/ampapi": "^1.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "monaco-editor": "^0.55.1",
    "ssh2": "^1.17.0",
    "unzipper": "^0.12.5"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "ssh2@1.17.0": true
  }
}
